{
  "name": "godot",
  "label": "Godot",
  "description": "Reference domain: build Godot-family (Godot / Redot / Blazium) games. Reproduces the framework's original behavior — selecting it changes nothing. This is the upstream-compat default, not a xenomoon product package.",
  "populated": true,
  "engine": {
    "name": "godot",
    "projectFile": "project.godot",
    "needsBinary": true
  },
  "inventory": {
    "scenes": [".tscn"],
    "scripts": [".gd"],
    "ignore": []
  },
  "starter": "starter",
  "materializeIntoProject": true,
  "plugin": "plugin",
  "builders": [
    "godot-dev",
    "godot-refactor",
    "godot-combat",
    "godot-player",
    "godot-visuals",
    "godot-assets"
  ],
  "orchestrator": "ui/orchestrator.md",
  "commands": {
    "validate": "tools/validate.sh",
    "verify_scene": "$GODOT --headless --path . --script tools/verify_scene.gd",
    "smoke": "$GODOT --headless --path . --quit-after 3",
    "render_check": "$GODOT --path . --resolution 640x360 -s tools/verify_render.gd",
    "screenshot": "$GODOT --path . --resolution 640x360 -s tools/capture_screenshot.gd"
  }
}
