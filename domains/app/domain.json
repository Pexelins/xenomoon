{
  "name": "app",
  "label": "App",
  "description": "Empty starter package for application development (Node/web today). Ships NO pre-baked capabilities — it learns the project. Experimental POC; not a committed product surface.",
  "populated": false,
  "engine": {
    "name": "node",
    "projectFile": "package.json"
  },
  "inventory": {
    "scenes": [],
    "scripts": [".js", ".ts", ".jsx", ".tsx"],
    "ignore": ["node_modules", "dist", "build", "out", "coverage"]
  },
  "materializeIntoProject": false,
  "plugin": "domains/app/plugin",
  "orchestrator": "domains/app/orchestrator.md",
  "commands": {
    "build": "npm run build --if-present",
    "lint": "npm run lint --if-present",
    "test": "npm test --if-present"
  }
}
